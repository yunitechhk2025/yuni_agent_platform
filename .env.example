# ==========================================
# Dify API 基础配置
# ==========================================
DIFY_API_BASE_URL=http://localhost/v1

# ==========================================
# Agent 1: 痛点分析助手
# ==========================================
AGENT_PAINPOINT_API_KEY=your_painpoint_agent_api_key_here
AGENT_PAINPOINT_INPUT_KEY=painpoint

# ==========================================
# Agent 2: 智能投研助手
# ==========================================
AGENT_INVESTMENT_API_KEY=your_investment_agent_api_key_here
AGENT_INVESTMENT_INPUT_KEY=query

# ==========================================
# AI 创意生成器 — APIMart (生图/生视频统一 API Key)
# ==========================================
GENERATE_API_KEY=your_api_key_here
# 你的服务器公网地址（APIMart 需要能访问上传的图片）
PUBLIC_BASE_URL=http://localhost:8000

# ==========================================
# Demo 申请邮件配置
# ==========================================
# Gmail 推荐使用「应用专用密码」(App Password)，不是账号密码
# 生成方式：Google 账户 → 安全性 → 两步验证 → 应用专用密码
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yunitechhk@gmail.com
SMTP_PASS=your_gmail_app_password_here
# 收件人 / 抄送（默认已预填，如无需改动可不设置）
APPLY_TO=info@yunitechhk.com
APPLY_CC=yunitechhk@gmail.com

# ==========================================
# 管理员直通密钥
# ==========================================
# 访问 https://yuniagent.ai/?admin=这里的值 即可免申请直接体验所有 Demo
# 建议设置为随机长字符串，例如：openssl rand -hex 24
ADMIN_SECRET=your_admin_secret_here

# ==========================================
# 服务配置
# ==========================================
HOST=0.0.0.0
PORT=8000
